generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ativo {
  id           Int      @id @default(autoincrement())
  nome         String
  tipo         String // 'caixinha_nubank' | 'tesouro' | 'acao' | 'etf' | 'fii'
  saldoInicial Float    @default(0)
  criadoEm     DateTime @default(now())

  metas Meta[]
}

model Meta {
  id             Int       @id @default(autoincrement())
  ativoId        Int
  valorAlvo      Float     @default(1000)
  valorAcumulado Float     @default(0)
  status         String    @default("ativa") // 'ativa' | 'concluida'
  iniciadaEm     DateTime  @default(now())
  concluidaEm    DateTime?

  ativo   Ativo    @relation(fields: [ativoId], references: [id])
  aportes Aporte[]
}

model Aporte {
  id            Int      @id @default(autoincrement())
  metaId        Int
  valorTotal    Float
  quantidade    Float? // null para caixinha_nubank
  valorUnitario Float? // null para caixinha_nubank
  data          DateTime @default(now())
  observacao    String?

  meta Meta @relation(fields: [metaId], references: [id])
}
